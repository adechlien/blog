---
import Layout from "../layouts/Layout.astro";
import About from "../components/About.astro";
import Recent from "../components/Recent.astro";
import Soon from "../components/Soon.astro";
import Collections from "../components/Collections.astro";
import History from "../components/History.astro";
import Destacados from "../components/Destacados.astro";
import Figures from "../components/Figures.astro";
import Albums from "../components/Albums.astro";
import Playlists from "../components/Playlists.astro";
import Footer from "../components/Footer.astro";
import Videos from "../components/Videos.astro";
import RecentSketches from "../components/RecentSketches.astro";
import { getCollection } from "astro:content";

const sketches = await getCollection("sketches");

const sortedSketches = sketches.sort(
  (a, b) =>
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

---

<Layout title="Inicio" description="Blog de textos literarios, prosa y reflexiones personales.">
    <main class="w-full max-w-[1100px] sm:max-w-none">
        <About />
        <section class="w-full px-6">
            <div class="mx-auto flex flex-col gap-12 sm:max-w-[1100px]">
                <Collections />
                <Recent />
                <Soon />
                <div class="grid grid-cols-1 lg:grid-cols-[1fr_200px] gap-12 sm:gap-8 items-start">
                <Destacados />
                    <History />
                </div>
                <Figures />
                <!-- <RecentSketches sketches={sortedSketches} /> -->
                <!-- <Videos /> -->
                <!-- <Playlists /> -->
                <Albums />
            </div>
        </section>
    </main>
    <Footer theme="home" />
</Layout>
