---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { getPayloadTexts } from "../lib/payload";

export const prerender = true;

export async function getStaticPaths() {
  const data = await getPayloadTexts();
  const posts = data.docs ?? [];

  const years = Array.from(
    new Set(
      posts
        .map((post: any) => {
          const date = new Date(post.pubDate);
          return Number.isNaN(date.getTime()) ? null : date.getFullYear();
        })
        .filter(Boolean)
    )
  );

  return years.map((year) => ({
    params: { year: String(year) },
  }));
}

const { year } = Astro.params;
const yearNum = Number(year);

const mapIcon = (type = "") => {
  if (type === "consciencia") return "/icons/bee.svg";
  if (type === "world") return "/icons/world.svg";
  if (type === "pintas") return "/icons/cupcake.svg";
  if (type === "lagrimas") return "/icons/cloud.svg";
  if (type === "still") return "/icons/heart.svg";
  if (type === "placebo") return "/icons/moon.svg";

  return "/icons/flower.svg";
};

const data = await getPayloadTexts();
const allPosts = data.docs ?? [];

const posts = allPosts
  .filter((post: any) => {
    const date = new Date(post.pubDate);

    if (Number.isNaN(date.getTime())) return false;

    return date.getFullYear() === yearNum;
  })
  .sort(
    (a: any, b: any) =>
      new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime()
  );

const heroBg = "/banner.svg";
const baseBg = "#024350";
---

<Layout title={`${year}`}>
  <Header />

  <main class="w-full max-w-[1100px] sm:max-w-none flex flex-col gap-16">
    <section class="relative overflow-hidden">
      <div
        class="relative w-full min-h-[70vh] bg-cover bg-bottom"
        style={`background-image: url(${heroBg});`}
      >
        <div
          class="sm:hidden pointer-events-none absolute inset-x-0 top-0 h-8"
          style={`background: linear-gradient(to top, rgba(0,0,0,0), ${baseBg});`}
        />

        <div
          class="pointer-events-none absolute inset-x-0 bottom-0 h-4"
          style={`background: linear-gradient(to bottom, rgba(0,0,0,0), ${baseBg});`}
        />
      </div>
    </section>

    <section class="flex flex-col gap-8 px-6 w-full max-w-6xl mx-auto">
      <h1 class="text-4xl font-bebas mb-10">{year}</h1>

      <ul class="grid gap-3 grid-cols-1 sm:grid-cols-4">
        {posts.length ? (
          posts.map((post: any) => {
            const collection = post.collection;
            const postTypeTitle = collection?.name ?? "";
            const icon = mapIcon(collection?.slug);
            const href = `/${collection?.slug}/${post.id}`;
            const coverUrl = post.cover?.url ?? "";
            const coverAlt = post.cover?.alt ?? post.title;

            return (
              <li>
                <a href={href} class="block group">
                  <div class="relative isolate overflow-hidden rounded-lg aspect-[2/1]">
                    {coverUrl && (
                      <img
                        src={coverUrl}
                        alt={coverAlt}
                        class="absolute inset-0 h-full w-full object-cover pointer-events-none select-none transition-transform duration-500 group-hover:scale-105"
                        loading="lazy"
                      />
                    )}

                    <div class="absolute bottom-0 flex flex-col justify-end gap-1 px-2 pb-1 pt-12 min-w-full bg-gradient-to-t from-human-4 to-transparent">
                      <p class="flex items-center gap-1 mt-auto text-xs text-human-2 font-black truncate">
                        <img src={icon} alt="" class="size-4" />
                        {postTypeTitle}
                      </p>

                      <h3 class="text-human-1 font-bebas text-start text-lg leading-6">
                        {post.title}
                      </h3>
                    </div>
                  </div>
                </a>
              </li>
            );
          })
        ) : (
          <li>No hay textos en este año.</li>
        )}
      </ul>

      <Footer theme="home" />
    </section>
  </main>
</Layout>
