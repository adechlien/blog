---
const { theme = "text", fg } = Astro.props;

const marginTop = theme === "home" ? "mt-20" : "mt-0";
const color = theme === "home" ? "text-human-2" : "text-human-1";
const borderColor = theme === "home" ? "border-human-3" : "border-human-1";
---
<footer class={`flex flex-col w-full px-6 pt-4 ${marginTop} mb-10 mx-auto lg:px-0 lg:max-w-[1100px] justify-between items-center text-center text-base border-t-2 ${borderColor} sm:border-t-0 sm:pt-0 ${color}`}>
  <span class="text-center font-bold">2023-2026</span>
  <p class="text-center font-medium">
    Desarrollado por
    <a href="https://adechlien.com" class="font-semibold" target="_blank">
      adechlien
    </a>
  </p>
  <!-- <span>lo que se habla en privado tiene que ser con tanto cuidado que uno esté dispuesto a ratificarlo en público</span> -->
</footer>
