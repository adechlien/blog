---
const socialLinks = [
  { href: "https://www.serializd.com/user/YourFriendlyADC/profile", text: "Serializd" },
  { href: "https://boxd.it/8fVlX", text: "Letterboxd" },
  { href: "https://www.instagram.com/adcpolo?igsh=OHF5c3A3azFrbGN1&utm_source=qr", text: "Instagram" },
];

const heroBg = "/banner.svg";
const avatar = "/avatar.webp";
---

<section class="relative overflow-hidden">
    <div class="relative w-full min-h-[70vh] bg-cover bg-bottom" style={`background-image: url(${heroBg});`}>
        <div class="sm:hidden pointer-events-none absolute inset-x-0 top-0 h-8 bg-gradient-to-t from-transparent to-human-4" ></div>
        <div class="pointer-events-none absolute inset-x-0 bottom-0 h-4 bg-gradient-to-b from-transparent to-human-4" ></div>

        <div class="absolute left-1/2 -translate-x-1/2 -bottom-10 z-20">
            <div class="size-36 rounded-full border-2 border-human-2 overflow-hidden">
                <img src={avatar} alt="Foto de perfil" class="w-full h-full object-cover" />
            </div>
        </div>
    </div>

  <div class="relative flex w-full flex-col gap-2 px-6 pt-14 pb-10 text-center sm:mx-auto">
    <h1 class="font-bebas text-3xl tracking-wide text-human-2 sm:text-5xl">
      Alejandro J. Hernández P.
    </h1>

    <nav
      aria-label="Redes sociales"
      class="flex flex-wrap items-center justify-center gap-x-1 gap-y-2 text-base text-human-2 sm:gap-x-4 sm:text-lg"
    >
      {socialLinks.map((link, index) => (
        <>
            <a href={link.href} target="_blank" rel="noopener noreferrer" class="px-1 underline-offset-4 hover:underline">
              {link.text}
            </a>

          <span class="text-human-3" aria-hidden="true">|</span>
        </>
      ))}

      <a href="https://pin.it/37CeFyEJI" target="_blank" rel="noopener noreferrer" class="px-2 underline-offset-4 hover:underline">
        Pinterest
      </a>
    </nav>

    <p class="font-tangerine text-xl leading-tight text-human-2 sm:text-2xl mt-8 md:mt-0">
      Donde reside todo lo que siento y no sé cómo decir.
      <br class="sm:hidden" />
      Donde espero llegues tú.
    </p>
  </div>
</section>
