---
import { getCollection } from "astro:content";
import FormattedDate from "./FormattedDate.astro";

const posts = await getCollection("texts");
const featured = posts.filter((p: any) => p.data.featured === true);
const sorted = posts.sort(
  (a: any, b: any) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const featuredPosts = (featured.length ? featured : sorted)
  .sort(
    (a: any, b: any) =>
      new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
  )
  .slice(0, 9);


const mapType = (type = "") => {
  if (type === "consciencia") return "Consciencia colménica";
  if (type === "lagrimas") return "Lágrimas de Siddartha";
  if (type === "colores") return "En las luces de colores";
  if (type === "still") return "Still Prefer Sentir";
  if (type === "placebo") return "Placebo Onírico";
  if (type === "pintas") return "Pintas Heredadas";
  return type;
};
---

<section class="w-full flex flex-col gap-3">
    <h3 class="text-4xl font-medium text-left font-bebas text-human-2 border-b-human-3 border-b-2">Destacados</h3>
    <ul class="grid grid-cols-1 md:grid-cols-4 gap-3 px-3">
        {featuredPosts.map((post: any) => (
        <li class="w-full">
            <a href={`/${post.data.type}/${post.slug}`} class="block">
                <div class="relative isolate overflow-hidden rounded aspect-[2/1]">
                    <img src={post.data.heroImage} alt={post.data.title} class="absolute inset-0 h-full w-full object-cover pointer-events-none select-none" loading="lazy"/>

                    <div class="absolute bottom-0 flex flex-col justify-end px-2 pb-1 pt-12 min-w-full bg-gradient-to-t from-human-4 to-transparent">
                        <p class="flex items-center gap-1 mt-auto text-xs text-human-2 font-black truncate">
                            <FormattedDate date={post.data.pubDate} />
                        </p>
                        <h3 class="text-human-1 font-bebas text-start text-lg leading-tight">
                          {post.data.title}
                        </h3>
                    </div>
                </div>
            </a>
        </li>
        ))}
    </ul>
</section>
