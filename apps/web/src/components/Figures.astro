---
import { getPayloadFigures } from "../lib/payload";
import { richTextToHtml } from "../lib/richTextToHtml";

const data = await getPayloadFigures();
const figures = data.docs ?? [];

const featuredFigures = figures
  .filter((figure: any) => figure.featured === true)
  .sort((a: any, b: any) => (a.order ?? 0) - (b.order ?? 0))
  .slice(0, 5);

const formatLifeSpan = (figure: any) => {
  if (figure.lifeSpanLabel) return figure.lifeSpanLabel;

  const birthYear = figure.birthDate ? new Date(figure.birthDate).getFullYear() : null;
  const deathYear = figure.deathDate ? new Date(figure.deathDate).getFullYear() : null;

  if (birthYear && deathYear) return `${birthYear}–${deathYear}`;
  if (birthYear && !deathYear) return `${birthYear}–actualidad`;

  return "";
};

const getContributionImageUrl = (image: any) => {
  if (!image?.url) return "";
  if (image.url.startsWith("http")) return image.url;

  return `${import.meta.env.PAYLOAD_URL ?? "http://localhost:3000"}${image.url}`;
};
---

<section class="w-full">
  <div class="flex flex-col gap-3 sm:mx-auto">
    <h3 class="text-4xl font-medium text-left font-bebas text-human-2 border-b-human-3 border-b-2">
      Ilustres del camino
    </h3>

    {featuredFigures.length > 0 ? (
      <ul class="flex flex-col sm:grid sm:grid-cols-4 gap-3 px-3">
        {featuredFigures.map((figure: any) => {
          const imageUrl = figure.cover?.url ?? "";
          const imageAlt = figure.cover?.alt ?? figure.name;

          return (
            <li>
              <button type="button" class="group block w-full text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-human-3" data-figure-open={figure.slug} aria-label={`Abrir ilustre ${figure.name}`}>
                <article class="flex justify-center relative aspect-[2/1] rounded overflow-hidden">
                  {imageUrl && <img src={imageUrl} alt={imageAlt} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />}

                  <div class="absolute bottom-0 flex flex-col justify-end px-2 pb-1 pt-12 min-w-full bg-gradient-to-t from-human-4 to-transparent">
                    <p class="font-bellota text-base text-human-1 text-right leading-4">
                      {figure.kind}
                    </p>

                    <p class="font-bebas text-2xl text-human-1 text-right">
                      {figure.name}
                    </p>
                  </div>
                </article>
              </button>
            </li>
          );
        })}
      </ul>
    ) : (
      <p class="px-3 text-sm text-human-2">
        No hay ilustres destacados todavía.
      </p>
    )}
  </div>

  <div id="figures-modal-backdrop" class="fixed inset-0 z-[100] hidden min-h-[100dvh] bg-black/70 opacity-0 backdrop-blur-sm transition-opacity duration-300 ease-out" data-figures-backdrop>
    <div class="flex min-h-[100dvh] w-full items-center justify-center p-3 sm:p-6">
      <div class="figure-modal-shell relative max-h-[calc(100dvh-1.5rem)] w-full max-w-6xl translate-y-16 overflow-hidden rounded-2xl border border-white/20 bg-human-4 text-human-1 opacity-0 shadow-2xl transition-[transform,opacity] duration-500 ease-out" role="dialog" aria-modal="true" aria-labelledby="figure-modal-title" data-figures-modal>
        <button type="button" class="absolute right-4 top-4 z-30 inline-flex size-9 items-center justify-center text-2xl text-human-1" data-figure-close aria-label="Cerrar modal">
          <i class="ti ti-x"></i>
        </button>

        <div class="max-h-[calc(100dvh-1.5rem)] overflow-y-auto overscroll-contain pb-[env(safe-area-inset-bottom)]" data-figures-scroll>
          {featuredFigures.map((figure: any) => {
            const bg = figure.backgroundColor ?? "#080809";
            const biographyHtml = richTextToHtml(figure.biography);
            const lifeSpan = formatLifeSpan(figure);

            return (
              <article class="hidden min-h-[84vh] flex-col" data-figure-panel={figure.slug} style={`background-color: ${bg};`}>
                <div class="figure-cover-sticky sticky top-0 z-20 w-full overflow-hidden" data-figure-cover>
                  {figure.cover?.url && <img src={figure.cover.url} alt={figure.cover.alt} class="h-full w-full object-cover object-center transition-transform duration-300 ease-out" loading="lazy" data-figure-cover-img />}

                  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-40" style={`background: linear-gradient(to bottom, rgba(0,0,0,0), ${bg});`}></div>

                  <div class="absolute bottom-0 left-0 right-0 px-6 pb-8 lg:px-10">
                    <header class="border-b-2 border-white/40 pb-4">
                      <h1 id="figure-modal-title" class="font-bebas text-4xl leading-none">
                        {figure.name}
                      </h1>

                      {lifeSpan && (
                        <p class="mt-2 font-besley text-base opacity-80">
                          ({lifeSpan})
                        </p>
                      )}

                      {figure.isFictional && (
                        <div class="mt-4 max-w-3xl rounded-lg border border-white/20 bg-black/30 p-4 font-besley text-sm leading-relaxed backdrop-blur-sm">
                          {figure.fictionalNotice}
                        </div>
                      )}
                    </header>
                  </div>
                </div>

                <section class="relative z-10 flex flex-1 flex-col px-6 py-8 lg:px-10 lg:py-10">
                  <article class="font-besley text-base leading-relaxed text-justify" set:html={biographyHtml} />

                  {figure.contributions?.length > 0 && (
                    <section class="my-10">
                      <div class="flex flex-col gap-4 columns-1 sm:columns-2 xl:columns-3 font-besley text-base">
                        {figure.contributions.map((item: any) => {
                          if (item.blockType === "quote") {
                            return (
                              <article class="break-inside-avoid flex flex-col gap-4 rounded-lg border border-white/20 bg-black/20 p-4 italic leading-relaxed shadow-md backdrop-blur-sm">
                                <p class="text-sm">“{item.text}”</p>

                                {item.source && (
                                  <span class="text-right text-xs font-bold not-italic tracking-wide opacity-70">
                                    {item.source}
                                  </span>
                                )}
                              </article>
                            );
                          }

                          if (item.blockType === "link") {
                            return (
                              <article class="break-inside-avoid mb-5 rounded-lg border border-white/20 bg-black/20 p-5 leading-relaxed shadow-md backdrop-blur-sm">
                                <h3 class="font-bebas text-2xl">
                                  {item.title}
                                </h3>

                                {item.description && (
                                  <p class="mt-2 opacity-80">
                                    {item.description}
                                  </p>
                                )}

                                <a href={item.url} target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex items-center gap-2 text-sm font-bold underline">
                                  Abrir link
                                  <i class="ti ti-external-link"></i>
                                </a>
                              </article>
                            );
                          }

                          if (item.blockType === "repository") {
                            return (
                              <article class="break-inside-avoid mb-5 rounded-lg border border-white/20 bg-black/20 p-5 leading-relaxed shadow-md backdrop-blur-sm">
                                <div class="mb-3 flex items-center gap-2">
                                  <i class="ti ti-brand-github text-xl"></i>

                                  <h3 class="font-bebas text-2xl">
                                    {item.title}
                                  </h3>
                                </div>

                                {item.description && (
                                  <p class="opacity-80">
                                    {item.description}
                                  </p>
                                )}

                                <a href={item.url} target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex items-center gap-2 text-sm font-bold underline">
                                  Ver repositorio
                                  <i class="ti ti-external-link"></i>
                                </a>
                              </article>
                            );
                          }

                          if (item.blockType === "image") {
                            const imageUrl = getContributionImageUrl(item.image);

                            return (
                              <figure class="break-inside-avoid mb-5 overflow-hidden rounded-lg border border-white/20 bg-black/20 shadow-md">
                                {imageUrl && <img src={imageUrl} alt={item.caption ?? ""} class="w-full object-cover" loading="lazy" />}

                                {item.caption && (
                                  <figcaption class="p-3 text-sm opacity-80">
                                    {item.caption}
                                  </figcaption>
                                )}
                              </figure>
                            );
                          }

                          if (item.blockType === "note") {
                            const noteHtml = richTextToHtml(item.content);

                            return (
                              <article class="break-inside-avoid mb-5 rounded-lg border border-white/20 bg-black/20 p-5 leading-relaxed shadow-md backdrop-blur-sm">
                                {item.title && (
                                  <h3 class="mb-3 font-bebas text-2xl">
                                    {item.title}
                                  </h3>
                                )}

                                <div set:html={noteHtml} />
                              </article>
                            );
                          }

                          return null;
                        })}
                      </div>
                    </section>
                  )}
                </section>
              </article>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .figure-cover-sticky {
    height: var(--figure-cover-height, 58dvh);
    min-height: var(--figure-cover-min-height, 300px);
    transition: height 180ms linear, min-height 180ms linear;
    will-change: height;
  }

  [data-figure-cover-img] {
    transition: transform 180ms linear;
    will-change: transform;
  }

  .figure-cover-sticky.is-compact {
    --figure-cover-height: 30dvh;
    --figure-cover-min-height: 190px;
  }

  .figure-cover-sticky.is-compact [data-figure-cover-img] {
    transform: scale(1.03);
  }

  [data-figures-backdrop].is-open {
    opacity: 1;
  }

  [data-figures-modal].is-open {
    transform: translateY(0);
    opacity: 1;
  }

  [data-figures-modal].is-closing {
    transform: translateY(4rem);
    opacity: 0;
  }

  @media (min-width: 1024px) {
    .figure-cover-sticky {
      --figure-cover-height: 70dvh;
      --figure-cover-min-height: 420px;
    }

    .figure-cover-sticky.is-compact {
      --figure-cover-height: 36dvh;
      --figure-cover-min-height: 260px;
    }
  }

  @media (max-width: 640px) {
    .figure-cover-sticky {
      --figure-cover-height: 56dvh;
      --figure-cover-min-height: 290px;
    }

    .figure-cover-sticky.is-compact {
      --figure-cover-height: 28dvh;
      --figure-cover-min-height: 180px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .figure-cover-sticky,
    [data-figures-backdrop],
    [data-figures-modal],
    [data-figure-cover-img] {
      transition: none !important;
    }
  }
</style>

<script is:inline>
  const backdrop = document.querySelector("[data-figures-backdrop]");
  const modal = document.querySelector("[data-figures-modal]");
  const scrollContainer = document.querySelector("[data-figures-scroll]");
  const openButtons = document.querySelectorAll("[data-figure-open]");
  const closeButton = document.querySelector("[data-figure-close]");
  const panels = document.querySelectorAll("[data-figure-panel]");

  let activePanel = null;
  let isClosing = false;
  let ticking = false;

  const lockPageScroll = () => {
    document.documentElement.classList.add("overflow-hidden");
    document.body.classList.add("overflow-hidden");
  };

  const unlockPageScroll = () => {
    document.documentElement.classList.remove("overflow-hidden");
    document.body.classList.remove("overflow-hidden");
  };

  const resetCovers = () => {
    panels.forEach((panel) => {
      const cover = panel.querySelector("[data-figure-cover]");
      cover?.classList.remove("is-compact");
    });
  };

  const updateActiveCover = () => {
    if (!scrollContainer || !activePanel) return;

    const cover = activePanel.querySelector("[data-figure-cover]");
    if (!cover) return;

    const scrollTop = scrollContainer.scrollTop;
    const isCompact = cover.classList.contains("is-compact");

    if (!isCompact && scrollTop > 60) {
      cover.classList.add("is-compact");
    }

    if (isCompact && scrollTop < 20) {
      cover.classList.remove("is-compact");
    }
  };

  const requestCoverUpdate = () => {
    if (ticking) return;

    ticking = true;

    window.requestAnimationFrame(() => {
      updateActiveCover();
      ticking = false;
    });
  };

  const hideAllPanels = () => {
    panels.forEach((panel) => {
      panel.classList.add("hidden");
      panel.classList.remove("flex");
    });
  };

  const closeModal = () => {
    if (!backdrop || !modal || isClosing) return;

    isClosing = true;

    modal.classList.remove("is-open");
    modal.classList.add("is-closing");
    backdrop.classList.remove("is-open");

    window.setTimeout(() => {
      backdrop.classList.add("hidden");
      modal.classList.remove("is-closing");
      unlockPageScroll();
      hideAllPanels();
      resetCovers();

      activePanel = null;
      isClosing = false;

      if (scrollContainer) {
        scrollContainer.scrollTop = 0;
      }
    }, 500);
  };

  const openModal = (slug) => {
    if (!backdrop || !modal || isClosing) return;

    hideAllPanels();

    panels.forEach((panel) => {
      const isTarget = panel.getAttribute("data-figure-panel") === slug;

      if (isTarget) {
        panel.classList.remove("hidden");
        panel.classList.add("flex");
        activePanel = panel;
      }
    });

    if (scrollContainer) {
      scrollContainer.scrollTop = 0;
    }

    resetCovers();
    backdrop.classList.remove("hidden");
    lockPageScroll();

    window.requestAnimationFrame(() => {
      backdrop.classList.add("is-open");
      modal.classList.add("is-open");
      requestCoverUpdate();
    });
  };

  openButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const slug = button.getAttribute("data-figure-open");
      if (!slug) return;

      if (button instanceof HTMLElement) button.blur();

      openModal(slug);
    });
  });

  closeButton?.addEventListener("click", closeModal);

  scrollContainer?.addEventListener("scroll", requestCoverUpdate, { passive: true });

  backdrop?.addEventListener("click", (event) => {
    if (event.target === backdrop) closeModal();
  });

  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") closeModal();
  });
</script>
