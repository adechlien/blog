---
import { getPayloadFigures } from "../lib/payload";

const data = await getPayloadFigures();
const figures = data.docs ?? [];

const featuredFigures = figures
  .filter((figure: any) => figure.featured === true)
  .sort((a: any, b: any) => (a.order ?? 0) - (b.order ?? 0))
  .slice(0, 5);
---

<section class="w-full">
  <div class="flex flex-col gap-3 sm:mx-auto">
    <h3 class="text-4xl font-medium text-left font-bebas text-human-2 border-b-human-3 border-b-2">
      Ilustres del camino
    </h3>

    {featuredFigures.length > 0 ? (
      <ul class="flex flex-col sm:grid sm:grid-cols-4 gap-3 px-3">
        {featuredFigures.map((figure: any) => {
          const imageUrl = figure.cover?.url ?? "";
          const imageAlt = figure.cover?.alt ?? figure.name;
          const href = `/figures/${figure.slug}`;

          return (
            <li>
              <a href={href} class="group block w-full text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-human-3" aria-label={`Abrir ilustre ${figure.name}`}>
                <article class="flex justify-center relative aspect-[2/1] rounded overflow-hidden">
                  {imageUrl && <img src={imageUrl} alt={imageAlt} class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />}

                  <div class="absolute bottom-0 flex flex-col justify-end px-2 pb-1 pt-12 min-w-full bg-gradient-to-t from-human-4 to-transparent">
                    <p class="font-bellota text-base text-human-1 text-right leading-4">
                      {figure.kind}
                    </p>

                    <p class="font-bebas text-2xl text-human-1 text-right">
                      {figure.name}
                    </p>
                  </div>
                </article>
              </a>
            </li>
          );
        })}
      </ul>
    ) : (
      <p class="px-3 text-sm text-human-2">
        No hay ilustres destacados todavía.
      </p>
    )}
  </div>
</section>
