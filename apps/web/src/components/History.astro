---
import { getPayloadTexts } from "../lib/payload";

const data = await getPayloadTexts();
const posts = data.docs ?? [];

const yearCount: Record<number, number> = {};

posts.forEach((post: any) => {
  const date = new Date(post.pubDate);

  if (Number.isNaN(date.getTime())) return;

  const year = date.getFullYear();

  yearCount[year] = (yearCount[year] || 0) + 1;
});

const years = Object.keys(yearCount)
  .map(Number)
  .sort((a, b) => b - a);

const yearHref = (year: number) => `/${year}/`;

const modalPosts = posts
  .filter((post: any) => post.pubDate)
  .map((post: any) => {
    const pubDate = new Date(post.pubDate);
    const type = post.collection?.slug ?? "";

    return {
      id: post.id,
      title: post.title,
      type,
      href: `/${type}/${post.id}`,
      coverUrl: post.cover?.url ?? "",
      coverAlt: post.cover?.alt ?? post.title,
      pubDate: post.pubDate,
      year: Number.isNaN(pubDate.getTime()) ? "" : String(pubDate.getFullYear()),
      formattedDate: Number.isNaN(pubDate.getTime())
        ? ""
        : pubDate.toLocaleDateString("es-CO", {
            day: "numeric",
            month: "long",
            year: "numeric",
          }),
    };
  })
  .filter((post: any) => post.year && post.type);
---

<aside class="w-full flex flex-col gap-3">
  <h3 class="text-4xl font-medium text-left font-bebas text-human-2 border-b-human-3 border-b-2">
    Historial
  </h3>

  <ul class="flex flex-col gap-2 px-3">
    {
      years.map((year) => (
        <li>
          <button data-history-modal-trigger data-history-year={year} class="flex justify-between items-center text-human-2 text-3xl sm:text-2xl font-bebas tracking-wide transition hover:text-human-1 w-full" aria-label={`Abrir textos del año ${year}`}>
            <span>{year}</span>

            <span class="text-sm font-bold text-human-2 font-bellota">
              {yearCount[year]}
            </span>
          </button>
        </li>
      ))
    }
  </ul>
</aside>

<div id="history-modal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-human-5/75 px-4 py-6 backdrop-blur-sm" aria-hidden="true">
  <div class="relative flex max-h-[96vh] w-full max-w-5xl flex-col overflow-hidden rounded-lg bg-human-4 text-human-2 shadow-2xl" role="dialog" aria-modal="true" aria-labelledby="history-modal-title">
    <header class="relative p-4 pt-8 sm:px-8 sm:pt-8">
        <div class="absolute -bottom-12 left-0 flex min-w-full flex-col justify-end bg-gradient-to-b from-human-4 to-transparent px-2 pt-12 z-50" ></div>

        <h2 id="history-modal-title" class="font-bebas text-4xl font-medium leading-none text-human-2 sm:text-6xl" ></h2>
    </header>

    <div id="history-modal-list" class="grid max-h-[58vh] grid-cols-1 gap-4 overflow-y-auto p-4 sm:grid-cols-2 lg:grid-cols-3 sm:p-8" ></div>
  </div>
</div>

<script define:vars={{ modalPosts }}>
  const posts = modalPosts;

  const modal = document.getElementById("history-modal");
  const titleElement = document.getElementById("history-modal-title");
  const listElement = document.getElementById("history-modal-list");

  const openClass = "flex";
  const closedClass = "hidden";

  function clearList() {
    while (listElement.firstChild) {
      listElement.removeChild(listElement.firstChild);
    }
  }

  function createPostCard(post) {
    const item = document.createElement("article");

    const link = document.createElement("a");
    link.href = post.href;
    link.className = "group block";

    const imageWrapper = document.createElement("div");
    imageWrapper.className =
      "relative isolate overflow-hidden rounded-lg aspect-[2/1]";

    if (post.coverUrl) {
      const image = document.createElement("img");
      image.src = post.coverUrl;
      image.alt = post.coverAlt || post.title;
      image.loading = "lazy";
      image.className =
        "absolute inset-0 h-full w-full object-cover pointer-events-none select-none transition-transform";

      imageWrapper.appendChild(image);
    }

    const overlay = document.createElement("div");
    overlay.className =
      "absolute bottom-0 flex min-w-full flex-col justify-end bg-gradient-to-t from-human-4 to-transparent px-2 pb-1 pt-12";

    const date = document.createElement("p");
    date.className =
      "mt-auto flex items-center gap-1 truncate text-xs font-black text-human-2";
    date.textContent = post.formattedDate;

    const heading = document.createElement("h3");
    heading.className =
      "text-start font-bebas text-lg leading-6 text-human-1";
    heading.textContent = post.title;

    overlay.appendChild(date);
    overlay.appendChild(heading);
    imageWrapper.appendChild(overlay);

    link.appendChild(imageWrapper);
    item.appendChild(link);

    return item;
  }

  function openModal(year) {
    const filteredPosts = posts
      .filter((post) => post.year === String(year))
      .sort(
        (a, b) =>
          new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime()
      );

    titleElement.textContent = year;

    clearList();

    if (filteredPosts.length === 0) {
      const emptyMessage = document.createElement("p");
      emptyMessage.className = "text-human-2/70";
      emptyMessage.textContent = "No hay textos registrados en este año.";

      listElement.appendChild(emptyMessage);
    } else {
      filteredPosts.forEach((post) => {
        listElement.appendChild(createPostCard(post));
      });
    }

    modal.classList.remove(closedClass);
    modal.classList.add(openClass);
    modal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    modal.classList.add(closedClass);
    modal.classList.remove(openClass);
    modal.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  document.addEventListener("click", (event) => {
    const trigger = event.target.closest("[data-history-modal-trigger]");

    if (!trigger) return;

    event.preventDefault();

    const year = trigger.dataset.historyYear;

    if (!year) return;

    openModal(year);
  });

  modal?.addEventListener("click", (event) => {
    if (event.target === modal) {
      closeModal();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && !modal.classList.contains(closedClass)) {
      closeModal();
    }
  });
</script>
