---
interface Sketch {
  slug: string;
  data: {
    title: string;
    date: string;
    pubDate: Date;
    image: string;
    alt?: string;
    note: string;
  };
}

interface Props {
  sketches: Sketch[];
}

const { sketches } = Astro.props;
---

<section class="w-full">
  <div class="columns-1 gap-5 sm:columns-2 lg:columns-3">
    {
      sketches.map((sketch) => (
        <article class="mb-5 break-inside-avoid">
            <button type="button" class="group w-full text-left" data-sketch-open data-title={sketch.data.title} data-date={sketch.data.date} data-image={sketch.data.image} data-alt={sketch.data.alt ?? sketch.data.title} data-note={sketch.data.note} aria-label={`Abrir sketch ${sketch.data.title}`}>
            <div class="overflow-hidden rounded-lg">
                <img src={sketch.data.image} alt={sketch.data.alt ?? sketch.data.title} loading="lazy" class="h-auto w-full object-cover"/>
            </div>

            <div class="mt-3">
              <h3 class="font-bebas text-xl leading-tight text-human-1">
                {sketch.data.title}
              </h3>

              <p class="text-sm text-human-2/70">
                {sketch.data.date}
              </p>
            </div>
          </button>
        </article>
      ))
    }
  </div>

  <dialog id="sketch-modal" class="w-[min(92vw,900px)] border border-human-3/40 bg-human-4 p-0 text-human-1 backdrop:bg-human-1/60">
    <div class="grid max-h-[90vh] overflow-y-auto md:grid-cols-[1.2fr_0.8fr]">
      <div class="bg-human-1/5">
          <img id="sketch-modal-image" src="" alt="" class="h-auto max-h-[85vh] w-full object-contain"/>
      </div>

      <div class="flex flex-col p-5 sm:p-6">
        <div class="flex items-start justify-between gap-4">
          <div>
              <p id="sketch-modal-date" class="text-sm text-human-2/70">
              </p>
            <h2 id="sketch-modal-title" class="mt-2 font-serif text-2xl leading-tight text-human-1"></h2>
          </div>

          <button type="button" id="sketch-modal-close" class="border border-human-3/40 px-3 py-1 text-sm text-human-2 transition-colors hover:bg-human-3/10" aria-label="Cerrar modal">
            Cerrar
          </button>
        </div>

        <div class="mt-6 border-t border-human-3/40 pt-5">
            <p id="sketch-modal-note" class="text-base leading-relaxed text-human-2">
            </p>
        </div>
      </div>
    </div>
  </dialog>
</section>


<script>
  const modal = document.querySelector("#sketch-modal");
  const modalImage = document.querySelector("#sketch-modal-image");
  const modalTitle = document.querySelector("#sketch-modal-title");
  const modalDate = document.querySelector("#sketch-modal-date");
  const modalNote = document.querySelector("#sketch-modal-note");
  const closeButton = document.querySelector("#sketch-modal-close");
  const openButtons = document.querySelectorAll("[data-sketch-open]");

  const isDialog = modal instanceof HTMLDialogElement;

  const closeModal = () => {
    if (!isDialog) return;

    modal.close();
    document.body.style.overflow = "";
  };

  openButtons.forEach((button) => {
    button.addEventListener("click", () => {
      if (!isDialog) return;

      const title = button.getAttribute("data-title") ?? "";
      const date = button.getAttribute("data-date") ?? "";
      const image = button.getAttribute("data-image") ?? "";
      const alt = button.getAttribute("data-alt") ?? title;
      const note = button.getAttribute("data-note") ?? "";

      if (modalImage instanceof HTMLImageElement) {
        modalImage.src = image;
        modalImage.alt = alt;
      }

      if (modalTitle) modalTitle.textContent = title;
      if (modalDate) modalDate.textContent = date;
      if (modalNote) modalNote.textContent = note;

      modal.showModal();
      document.body.style.overflow = "hidden";
    });
  });

  closeButton?.addEventListener("click", closeModal);

  modal?.addEventListener("click", (event) => {
    if (!isDialog) return;

    if (!(event instanceof MouseEvent)) return;

    const rect = modal.getBoundingClientRect();

    const clickedOutside =
      event.clientX < rect.left ||
      event.clientX > rect.right ||
      event.clientY < rect.top ||
      event.clientY > rect.bottom;

    if (clickedOutside) {
      closeModal();
    }
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      document.body.style.overflow = "";
    }
  });
</script>
